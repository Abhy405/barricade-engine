{
  "manifest_version": 3,
  "name": "Barricade Engine",
  "version": "1.1",
  "description": "Quoridor engine overlay for barricade.gg",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [],
  "host_permissions": [
    "http://127.0.0.1:5123/*"
  ],
  "content_scripts": [
    {
      "js": ["scripts/main.js"],
      "css": ["scripts/overlay.css"],
      "matches": [
        "https://barricade.gg/*",
        "https://www.barricade.gg/*"
      ],
      "run_at": "document_idle"
    }
  ]
}
